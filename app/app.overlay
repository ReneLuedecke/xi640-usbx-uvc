/ {
	chosen {
		zephyr,camera = &sw_generator;
	};

	sw_generator: sw-generator {
		compatible = "zephyr,video-sw-generator";
		status = "okay";
	};

	uvc: uvc {
		compatible = "zephyr,uvc-device";
		status = "okay";
	};

	/* Xi640 HID — Vendor Usage Page 0xFFA0 (Optris PIX Connect / IRImager SDK).
	 * Interface 2, ausserhalb der UVC-IAD (kein eigener IAD noetig).
	 * out-report-size → Interrupt-OUT-EP (0x02), Kommandos ohne Control-Pipe. */
	xi640_hid_dev: xi640-hid-dev {
		compatible = "zephyr,hid-device";
		protocol-code = "none";
		in-report-size        = <64>;
		in-polling-period-us  = <1000>;
		out-report-size       = <40>;
		out-polling-period-us = <1000>;
	};

};
